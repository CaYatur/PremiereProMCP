{
  "name": "PPMCP Diagnostic",
  "id": "com.premiereprocmp.diagnostic",
  "version": "0.1.0",
  "manifestVersion": 5,
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "26.0.0"
    }
  ],
  "entryPoints": [
    {
      "type": "panel",
      "id": "diagnosticPanel",
      "label": {
        "default": "PPMCP Diagnostic"
      },
      "minimumSize": { "width": 400, "height": 300 },
      "maximumSize": { "width": 800, "height": 1200 },
      "preferredDockedSize": { "width": 500, "height": 600 }
    }
  ],
  "requiredPermissions": {
    "clipboard": "readAndWrite"
  }
}
