{
  "name": "premiere-pro-mcp",
  "version": "1.0.2",
  "private": true,
  "description": "MCP server for real, deep editing control of Adobe Premiere Pro via UXP.",
  "workspaces": [
    "shared",
    "bridge",
    "server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:bridge": "npm run dev --workspace=bridge",
    "dev:server": "npm run dev --workspace=server",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "smoke-test": "npm run build && node scripts/smoke-test.mjs",
    "smoke-all": "npm run build && node scripts/smoke-all-tools.mjs",
    "test:media": "npm run build --workspace=server && node scripts/test-media-analysis.mjs",
    "release:win": "powershell -ExecutionPolicy Bypass -File installer/build-release.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
